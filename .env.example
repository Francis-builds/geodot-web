# Resend — transactional email for the contact form
# Get a key at https://resend.com (Fran configures .env.local with the real key)
RESEND_API_KEY=
CONTACT_TO=hola@geodot.app
CONTACT_FROM="Geodot Web <web@geodot.app>"

# Canonical site URL for metadata / OG / sitemap / robots.
# In production set this to the public domain. On Vercel previews,
# VERCEL_URL is used automatically when this is unset; final fallback is https://geodot.app.
NEXT_PUBLIC_SITE_URL=https://geodot.app
